---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div style="max-width: 1100px; margin: 0 auto; padding: 2rem 1rem;">
    <h1 style="font-size: 2.8rem; text-align: center; margin-bottom: 1rem;">Check Which States You Owe Sales Tax In</h1>
    <p style="text-align: center; font-size: 1.3rem; color: #475569; max-width: 700px; margin: 0 auto 3rem;">Free tool for Shopify, Etsy, and Amazon sellers</p>

    <p style="text-align: center; color: #64748b; margin-bottom: 4rem;">Full interactive calculator coming in next files...</p>

    <div style="text-align: center; padding: 4rem; background: #f8fafc; border-radius: 12px;">
      <p><strong>Site is being built step by step.</strong></p>
      <p>Continue following my instructions.</p>
    </div>
  </div>
</BaseLayout>
