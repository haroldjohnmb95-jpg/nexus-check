---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';

const { title = "Nexus Check — Free Sales Tax Nexus Tool", description = "Check economic nexus thresholds for all US states. Free tool for Shopify, Etsy & Amazon sellers." } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" />
  <style>
    :root {
      --navy: #1e3a8a;
      --green: #166534;
      --slate: #334155;
      --light: #f8fafc;
    }
    body { font-family: system-ui, sans-serif; background: var(--light); color: #0f172a; }
    .container { max-width: 1280px; margin: 0 auto; padding: 0 1rem; }
  </style>
</head>
<body>
  <Header />
  <DisclaimerBanner />
  <main><slot /></main>
  <Footer />
</body>
</html>
